# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (สำหรับรันบนเครื่องตัวเอง)
# บน GitHub Actions ให้ไปตั้งเป็น "Secrets" แทน ไม่ต้องใช้ไฟล์ .env

# คีย์ข้อมูลราคา (สมัครฟรี: https://twelvedata.com/)
TWELVEDATA_API_KEY=

# === Telegram (แนะนำ ฟรีไม่จำกัด) ===
# สร้างบอทผ่าน @BotFather ใน Telegram -> ได้ TELEGRAM_BOT_TOKEN
# chat id หาได้จาก @userinfobot หรือเปิด https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LINE (ไม่บังคับ — ตั้งช่องไหนก็ส่งช่องนั้น) ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO=

# === AI sentiment จากข่าว (ไม่บังคับ) ===
# DeepSeek: สมัคร https://platform.deepseek.com/ (ต้องเติมเงิน) -> DEEPSEEK_API_KEY
# อยากใช้ฟรี เปลี่ยนไป Groq/Gemini ได้ด้วย AI_BASE_URL + AI_MODEL (ดูใน ai_sentiment.py)
DEEPSEEK_API_KEY=
#AI_BASE_URL=https://api.deepseek.com
#AI_MODEL=deepseek-chat

# ส่งทุกชั่วโมงไหม? false = ส่งเฉพาะตอนสัญญาณเปลี่ยน (ประหยัด)
ALWAYS_SEND=false
